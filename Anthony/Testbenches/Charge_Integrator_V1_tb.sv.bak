
`timescale 1ns/1ps
`default_nettype none

module tb_charge_integrator_v1;

  localparam int ADC_WIDTH = 12;
  localparam int TS_WIDTH  = 52;
  localparam int SUM_WIDTH = 26;

  localparam int EDGE_CASE_TRIALS = 2000;
  localparam int TRIALS           = 20000;

  // Clock / Reset
  logic clk;
  logic rst_n;

  initial begin
    clk = 1'b0;
    forever #5ns clk = ~clk;
  end

  initial begin
    rst_n = 1'b1;
    #2ns;
    rst_n = 1'b0;
    #20ns;
    rst_n = 1'b1;
  end

  // DUT I/O
  logic                 in_valid;
  logic [ADC_WIDTH-1:0] adc0, adc1, adc2, adc3;
  logic [TS_WIDTH-1:0]  in_timestamp;

  logic                 out_valid;
  logic [SUM_WIDTH-1:0] out_sum;
  logic [TS_WIDTH-1:0]  out_timestamp;
  logic                 out_overflow;

  Charge_Integrator_V1 #(
    .ADC_WIDTH(ADC_WIDTH),
    .TS_WIDTH (TS_WIDTH),
    .SUM_WIDTH(SUM_WIDTH)
  ) dut (
    .clk          (clk),
    .rst_n        (rst_n),
    .in_valid     (in_valid),
    .adc0         (adc0),
    .adc1         (adc1),
    .adc2         (adc2),
    .adc3         (adc3),
    .in_timestamp (in_timestamp),
    .out_valid    (out_valid),
    .out_sum      (out_sum),
    .out_timestamp(out_timestamp),
    .out_overflow (out_overflow)
  );

  // Drive defaults
  initial begin
    in_valid     = 1'b0;
    adc0         = '0;
    adc1         = '0;
    adc2         = '0;
    adc3         = '0;
    in_timestamp = '0;
  end

  // ----------------------------
  // Reference model that matches DUT?s two always_ff ordering
  // (input regs updated in one always_ff, FSM uses *previous* reg values)
  // ----------------------------
  logic                 in_valid_r_m;
  logic [ADC_WIDTH-1:0] adc0_r_m, adc1_r_m, adc2_r_m, adc3_r_m;
  logic [TS_WIDTH-1:0]  ts_r_m;

  logic                 prev_valid_m;
  logic [SUM_WIDTH-1:0] cur_sum_m;
  logic                 cur_overflow_m;
  logic [TS_WIDTH-1:0]  registered_ts_m;

  // ?Expected outputs? for current cycle
  logic                 exp_out_valid;
  logic [SUM_WIDTH-1:0] exp_out_sum;
  logic [TS_WIDTH-1:0]  exp_out_ts;
  logic                 exp_out_overflow;

  int test_count = 0;

  logic [TS_WIDTH-1:0] ts;
  logic [TS_WIDTH-1:0] ts_of;

  // Compute adc_sum_ext as DUT does
  function automatic [SUM_WIDTH:0] adc_sum_ext_f(
    input logic [ADC_WIDTH-1:0] a0,
    input logic [ADC_WIDTH-1:0] a1,
    input logic [ADC_WIDTH-1:0] a2,
    input logic [ADC_WIDTH-1:0] a3
  );
    // ADC_SUM_WIDTH = ADC_WIDTH+2
    logic [ADC_WIDTH+1:0] adc_sum;
    logic [SUM_WIDTH:0]   ext;
    begin
      adc_sum = {{2{1'b0}}, a0} + {{2{1'b0}}, a1} + {{2{1'b0}}, a2} + {{2{1'b0}}, a3};
      ext = { {(SUM_WIDTH+1-(ADC_WIDTH+2)){1'b0}}, adc_sum };
      return ext;
    end
  endfunction

  // Reference model clocked
  always_ff @(posedge clk or negedge rst_n) begin
    if (!rst_n) begin
      // model regs
      in_valid_r_m     <= 1'b0;
      adc0_r_m         <= '0;
      adc1_r_m         <= '0;
      adc2_r_m         <= '0;
      adc3_r_m         <= '0;
      ts_r_m           <= '0;

      prev_valid_m     <= 1'b0;
      cur_sum_m        <= '0;
      cur_overflow_m   <= 1'b0;
      registered_ts_m  <= '0;

      exp_out_valid    <= 1'b0;
      exp_out_sum      <= '0;
      exp_out_ts       <= '0;
      exp_out_overflow <= 1'b0;
    end else begin
      // ------------------------
      // 1) FSM step uses *old* in_valid_r_m / adc*_r_m / ts_r_m
      // ------------------------
      exp_out_valid    <= 1'b0;
      exp_out_sum      <= '0;
      exp_out_ts       <= '0;
      exp_out_overflow <= 1'b0;

      if (in_valid_r_m) begin
        if (!prev_valid_m) begin
          // start of burst
          prev_valid_m    <= 1'b1;
          registered_ts_m <= ts_r_m;
          cur_sum_m       <= adc_sum_ext_f(adc0_r_m, adc1_r_m, adc2_r_m, adc3_r_m)[SUM_WIDTH-1:0];
          cur_overflow_m  <= 1'b0;
        end else begin
          // middle of burst
          logic [SUM_WIDTH:0] addend;
          logic [SUM_WIDTH:0] sum_plus;
          addend   = adc_sum_ext_f(adc0_r_m, adc1_r_m, adc2_r_m, adc3_r_m);
          sum_plus = {1'b0, cur_sum_m} + addend;
          cur_sum_m      <= sum_plus[SUM_WIDTH-1:0];
          cur_overflow_m <= cur_overflow_m | sum_plus[SUM_WIDTH];
          prev_valid_m   <= 1'b1;
        end
      end else begin
        if (prev_valid_m) begin
          // end of burst -> 1-cycle pulse
          exp_out_valid    <= 1'b1;
          exp_out_sum      <= cur_sum_m;
          exp_out_ts       <= registered_ts_m;
          exp_out_overflow <= cur_overflow_m;

          prev_valid_m     <= 1'b0;
          cur_sum_m        <= '0;
          cur_overflow_m   <= 1'b0;
          registered_ts_m  <= '0;
        end else begin
          // idle
          prev_valid_m     <= 1'b0;
          cur_sum_m        <= '0;
          cur_overflow_m   <= 1'b0;
          registered_ts_m  <= '0;
        end
      end

      // ------------------------
      // 2) Update the ?input register? stage (mirrors DUT input reg block)
      // ------------------------
      in_valid_r_m <= in_valid;
      adc0_r_m     <= adc0;
      adc1_r_m     <= adc1;
      adc2_r_m     <= adc2;
      adc3_r_m     <= adc3;
      ts_r_m       <= in_timestamp;

      // ------------------------
      // 3) Compare DUT vs expected for this cycle
      // ------------------------
      if (exp_out_valid) begin
        test_count++;

        assert(out_valid === 1'b1)
          else $fatal(1, "out_valid mismatch exp=1 got=%0b", out_valid);

        assert(out_sum === exp_out_sum)
          else $fatal(1, "out_sum mismatch exp=%0d got=%0d", exp_out_sum, out_sum);

        assert(out_timestamp === exp_out_ts)
          else $fatal(1, "out_timestamp mismatch exp=%0h got=%0h", exp_out_ts, out_timestamp);

        assert(out_overflow === exp_out_overflow)
          else $fatal(1, "out_overflow mismatch exp=%0b got=%0b", exp_out_overflow, out_overflow);
      end else begin
        // out_valid should only ever pulse when expected does
        assert(out_valid === 1'b0)
          else $fatal(1, "Unexpected out_valid pulse (got out_sum=%0d ts=%0h)", out_sum, out_timestamp);
      end
    end
  end

  // Stimulus helper
  task automatic drive_cycle(
    input logic                 v,
    input logic [ADC_WIDTH-1:0] a0,
    input logic [ADC_WIDTH-1:0] a1,
    input logic [ADC_WIDTH-1:0] a2,
    input logic [ADC_WIDTH-1:0] a3,
    input logic [TS_WIDTH-1:0]  ts
  );
    begin
      in_valid     = v;
      adc0         = a0;
      adc1         = a1;
      adc2         = a2;
      adc3         = a3;
      in_timestamp = ts;
      @(posedge clk);
    end
  endtask

  // Test sequence
  initial begin
    @(posedge rst_n);
    repeat (5) @(posedge clk);

    // --- Directed: single-sample burst (length=1)
    $display("[Charge TB] Directed: single-sample bursts");
    for (int i = 0; i < EDGE_CASE_TRIALS; i++) begin
      ts = {$urandom(), $urandom_range(0,(1<<20)-1)};
      drive_cycle(1'b1, $urandom(), $urandom(), $urandom(), $urandom(), ts);
      drive_cycle(1'b0, '0, '0, '0, '0, '0); // end burst
      // a couple idle cycles
      drive_cycle(1'b0, '0, '0, '0, '0, '0);
    end

    // --- Directed: constant max ADC, long burst to force overflow in 26-bit accumulator
    // Max per-cycle sum = 4*4095 = 16380. 26-bit max ~67M, so length ~5000 guarantees carry events.
    $display("[Charge TB] Directed: overflow forcing long burst");
    ts_of = 52'hABCDE;
    for (int k = 0; k < 6000; k++) begin
      drive_cycle(1'b1, 12'hFFF, 12'hFFF, 12'hFFF, 12'hFFF, ts_of);
    end
    drive_cycle(1'b0, '0, '0, '0, '0, '0);
    repeat (5) drive_cycle(1'b0, '0, '0, '0, '0, '0);

    // --- Random bursts with random lengths (including occasional 0/idle gaps)
    $display("[Charge TB] Random burst tests");
    for (int t = 0; t < TRIALS; t++) begin
      int burst_len = $urandom_range(1, 200); // moderate bursts
      ts = {$urandom(), $urandom_range(0,(1<<20)-1)};

      for (int k = 0; k < burst_len; k++) begin
        drive_cycle(1'b1,
                    $urandom_range(0, (1<<ADC_WIDTH)-1),
                    $urandom_range(0, (1<<ADC_WIDTH)-1),
                    $urandom_range(0, (1<<ADC_WIDTH)-1),
                    $urandom_range(0, (1<<ADC_WIDTH)-1),
                    ts);
      end

      // end burst (at least 1 idle cycle)
      drive_cycle(1'b0, '0, '0, '0, '0, '0);

      // occasional extra idle gap
      if (($urandom() % 4) == 0) begin
        int gap = $urandom_range(1, 5);
        repeat (gap) drive_cycle(1'b0, '0, '0, '0, '0, '0);
      end
    end

    $display("[Charge TB] PASS. Checked bursts (out_valid pulses): %0d", test_count);
    $stop;
  end

endmodule

`default_nettype wire
